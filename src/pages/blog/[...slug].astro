---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/astro/Header.astro";
import Footer from "../../components/astro/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Adrian Infantes`} description={post.data.description}>
  <Header />
  <main id="main" class="relative z-10 mx-auto max-w-3xl px-6 py-32">
    <a href="/blog" class="text-sm text-text-muted transition-colors hover:text-accent">
      &larr; Back to blog
    </a>

    <article class="mt-8">
      <div class="flex items-center gap-3 text-xs text-text-muted">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        {post.data.tags.map((tag: string) => (
          <span class="rounded bg-bg-tertiary px-2 py-0.5">{tag}</span>
        ))}
      </div>

      <h1 class="mt-4 text-4xl font-bold tracking-tight text-text-primary">
        {post.data.title}
      </h1>
      <p class="mt-2 text-lg text-text-secondary">{post.data.description}</p>

      <div class="mt-4 h-px w-16 bg-accent"></div>

      <div class="prose prose-invert mt-8 max-w-none prose-headings:text-text-primary prose-p:text-text-secondary prose-a:text-accent prose-code:text-accent prose-pre:bg-bg-secondary">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
