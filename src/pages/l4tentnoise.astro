---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>L4tentNoise</title>
  </head>
  <body class="bg-bg-primary text-text-primary">
    <div class="flex min-h-screen flex-col items-center justify-center px-6">
      <!-- Scanline overlay -->
      <div class="pointer-events-none fixed inset-0 z-50 opacity-[0.03]"
        style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(6,182,212,0.1) 2px, rgba(6,182,212,0.1) 4px);">
      </div>

      <div class="relative text-center">
        <p class="font-mono text-sm text-text-muted animate-pulse">
          [SIGNAL INTERCEPTED]
        </p>

        <h1 class="mt-6 font-mono text-5xl font-bold tracking-tight text-accent sm:text-7xl"
          style="text-shadow: 2px 2px 0 rgba(239,68,68,0.3), -1px -1px 0 rgba(6,182,212,0.3);">
          L4tentNoise
        </h1>

        <div class="mx-auto mt-4 h-px w-32 bg-gradient-to-r from-transparent via-accent to-transparent"></div>

        <p class="mt-6 font-mono text-text-secondary">
          HackTheBox &middot; Top 800 Global &middot; Offensive Security
        </p>

        <div class="mt-12 rounded-xl border border-border bg-bg-secondary/50 p-8 font-mono text-sm">
          <p class="text-accent">$ cat /dev/null > content.md</p>
          <p class="mt-2 text-text-muted">// Content incoming. Stay tuned.</p>
          <p class="mt-4 text-text-muted">
            <span class="text-accent-red">[TODO]</span> Adrian is loading this page with L4tentNoise data...
          </p>
        </div>

        <a
          href="/Web-AIR/"
          class="mt-10 inline-block font-mono text-sm text-text-muted transition-colors hover:text-accent"
        >
          &lt; back to surface
        </a>
      </div>
    </div>
  </body>
</html>
