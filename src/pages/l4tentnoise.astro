---
import L4tentLayout from "../layouts/L4tentLayout.astro";
import L4tentNoiseShell from "../components/react/L4tentNoiseShell";
import GlitchLayer from "../components/react/GlitchLayer";
import ParticleNetwork from "../components/react/ParticleNetwork";

const stats = [
  { label: "RANK", value: "#751", sub: "GLOBAL" },
  { label: "PTS", value: "232", sub: "ACCUMULATED" },
  { label: "FLAGS", value: "69", sub: "CAPTURED" },
  { label: "OWN%", value: "37.88", sub: "CONTENT" },
];

const difficulty = [
  { level: "EASY", count: 6, color: "#10b981" },
  { level: "MED", count: 4, color: "#f59e0b" },
  { level: "HARD", count: 4, color: "#ef4444" },
  { level: "INS", count: 0, color: "#8b5cf6" },
];

const compromised = [
  {
    target: "NVIDIA Nemotron",
    classification: "Foundation Model — 340B params",
    vectors: "Guardrail bypass, prompt injection, data exfiltration, tool abuse",
    status: "PWNED",
  },
  {
    target: "Microsoft Phi",
    classification: "SLM — Alignment target",
    vectors: "Multi-turn jailbreak, system prompt extraction, alignment bypass",
    status: "PWNED",
  },
  {
    target: "Foundation Models (aggregate)",
    classification: "Cross-vendor evaluation",
    vectors: "206+ vectors: injection, poisoning, extraction, manipulation",
    status: "7 CRITICAL",
  },
];

const activity = [
  { flag: "Jerry-built", type: "Fortress", ago: "7d" },
  { flag: "Shortcut", type: "Fortress", ago: "7d" },
  { flag: "Magnified", type: "Fortress", ago: "8d" },
  { flag: "Inspector", type: "Fortress", ago: "8d" },
  { flag: "Early Access", type: "Fortress", ago: "8d" },
];
---

<L4tentLayout>
    <!-- Particles persist from main page -->
    <div class="pointer-events-none fixed inset-0 z-0 hidden md:block" aria-hidden="true" transition:persist="particles">
      <ParticleNetwork client:load transition:persist />
    </div>

    <L4tentNoiseShell client:load>
      <!-- Persistent effects layer -->
      <GlitchLayer client:load />

      <!-- Scanline -->
      <div class="pointer-events-none fixed inset-0 z-50 overflow-hidden opacity-[0.03]">
        <div class="scanline-anim h-[2px] w-full bg-accent"></div>
      </div>

      <!-- CRT vignette -->
      <div class="pointer-events-none fixed inset-0 z-40"
        style="background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.5) 100%);">
      </div>

      <div class="relative z-10 mx-auto max-w-4xl px-6 py-8">

        <!-- System bar -->
        <div class="mb-8 flex flex-wrap items-center justify-between gap-4 border-b border-accent-red/20 pb-3 text-[10px] text-text-muted">
          <div class="flex items-center gap-4">
            <span class="flex items-center gap-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-accent-red animate-pulse"></span>
              UNSECURED SESSION
            </span>
            <span>PID: 4721</span>
            <span>TTY: pts/3</span>
          </div>
          <div class="flex items-center gap-4">
            <span>VPN: 10.10.14.x</span>
            <span>UPTIME: {Math.floor(Math.random() * 200 + 50)}h</span>
            <span class="text-accent-red">REC</span>
          </div>
        </div>

        <!-- Identity block -->
        <header class="mb-12">
          <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-[10px] text-accent-red tracking-[0.3em] uppercase mb-2">
                // CLASSIFIED — OPERATOR FILE
              </p>
              <h1 class="text-4xl sm:text-6xl font-bold tracking-tight"
                style="text-shadow: 2px 2px 0 rgba(239,68,68,0.2), -1px -1px 0 rgba(6,182,212,0.2);">
                <span class="text-accent">L4tent</span><span class="text-text-primary">Noise</span>
              </h1>
              <p class="mt-2 text-sm text-text-secondary">
                AI Red Teamer &middot; Adversarial ML Researcher &middot; Offensive Security
              </p>
            </div>
            <div class="flex flex-col items-end gap-2">
              <span class="rounded border border-accent-red/40 bg-accent-red/10 px-3 py-1 text-[10px] text-accent-red pulse-danger">
                THREAT LEVEL: HIGH
              </span>
              <div class="flex gap-2">
                <span class="rounded border border-accent-green/30 bg-accent-green/10 px-2 py-0.5 text-[10px] text-accent-green">HTB VIP+</span>
                <span class="rounded border border-accent/30 bg-accent/10 px-2 py-0.5 text-[10px] text-accent">KAGGLE MASTER</span>
              </div>
            </div>
          </div>
        </header>

        <!-- HTB Stats -->
        <section class="mb-10">
          <h2 class="mb-4 text-[10px] tracking-[0.2em] text-text-muted uppercase border-b border-border/50 pb-2">
            <span class="text-accent-red">&gt;</span> hackthebox_stats.db <span class="classified-stamp"></span>
          </h2>
          <div class="grid grid-cols-4 gap-3">
            {stats.map((s) => (
              <div class="rounded border border-border/50 bg-bg-secondary/30 p-3 text-center">
                <div class="text-xl font-bold text-accent">{s.value}</div>
                <div class="text-[9px] text-text-muted tracking-wider">{s.label}</div>
              </div>
            ))}
          </div>
          <div class="mt-3 grid grid-cols-4 gap-3">
            {difficulty.map((d) => (
              <div class="flex items-center gap-2 rounded border border-border/30 bg-bg-secondary/20 px-3 py-2">
                <span class="text-lg font-bold" style={`color: ${d.color};`}>{d.count}</span>
                <div class="flex-1">
                  <div class="text-[9px] text-text-muted">{d.level}</div>
                  <div class="mt-0.5 h-0.5 w-full rounded-full bg-bg-tertiary overflow-hidden">
                    <div class="h-full rounded-full" style={`width: ${Math.min(d.count * 15, 100)}%; background-color: ${d.color};`}></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-3 flex items-center gap-4 text-[10px] text-text-muted">
            <span>SEASON 10: Silver Tier</span>
            <span>|</span>
            <span>Seasonal #3997</span>
            <span>|</span>
            <span>220 pts</span>
            <span>|</span>
            <span>8/26 flags</span>
          </div>
        </section>

        <!-- COMPROMISED TARGETS -->
        <section class="mb-10">
          <h2 class="mb-4 text-[10px] tracking-[0.2em] text-accent-red uppercase border-b border-accent-red/30 pb-2">
            <span>&gt;</span> cat /var/log/engagements/ai_redteam.log
          </h2>
          <div class="space-y-3">
            {compromised.map((c) => (
              <div class="rounded border border-accent-red/20 bg-accent-red/[0.03] p-4">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <span class="text-base font-bold text-text-primary">{c.target}</span>
                    <span class="ml-2 text-[10px] text-text-muted">{c.classification}</span>
                  </div>
                  <span class="inline-flex items-center gap-1.5 rounded border border-accent-red/50 bg-accent-red/15 px-2.5 py-0.5 text-[10px] font-black text-accent-red tracking-wider"
                    style="text-shadow: 0 0 6px rgba(239,68,68,0.5);">
                    <span class="h-1.5 w-1.5 rounded-full bg-accent-red animate-pulse"></span>
                    {c.status}
                  </span>
                </div>
                <p class="mt-2 text-xs text-text-muted">{c.vectors}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Kaggle -->
        <section class="mb-10">
          <h2 class="mb-4 text-[10px] tracking-[0.2em] text-text-muted uppercase border-b border-border/50 pb-2">
            <span class="text-accent">&gt;</span> kaggle_profile --rank master
          </h2>
          <div class="rounded border border-accent/20 bg-accent/[0.03] p-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl font-bold text-accent">MASTER</span>
              <span class="text-xs text-text-muted">// Competitive ML — Top-tier rank</span>
            </div>
            <div class="mt-3 rounded border border-border/30 bg-bg-primary/50 p-3 text-xs">
              <p class="text-accent">$ ./triagegeist --eval</p>
              <p class="mt-1 text-text-secondary">
                QWK: <span class="text-accent-green font-bold">0.9998</span>
                &nbsp;|&nbsp; F1: <span class="text-accent-green font-bold">0.999</span>
                &nbsp;|&nbsp; ESI-1 Recall: <span class="text-accent-green font-bold">99.5%</span>
              </p>
              <p class="text-text-muted mt-1">Laitinen-Fredriksson Foundation // $10K prize pool</p>
            </div>
          </div>
        </section>

        <!-- Recent flags -->
        <section class="mb-10">
          <h2 class="mb-4 text-[10px] tracking-[0.2em] text-text-muted uppercase border-b border-border/50 pb-2">
            <span class="text-accent-green">&gt;</span> tail -f /var/log/flags.log
          </h2>
          <div class="space-y-1 text-xs">
            {activity.map((a) => (
              <div class="flex items-center gap-2 rounded bg-bg-secondary/20 px-3 py-1.5 border border-border/20">
                <span class="text-accent-green">FLAG</span>
                <span class="text-text-muted">{a.type}</span>
                <span class="text-text-primary font-medium">{a.flag}</span>
                <span class="ml-auto text-text-muted/50">{a.ago}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Footer terminal -->
        <footer class="mt-16 border-t border-border/30 pt-6">
          <div class="text-center">
            <div class="inline-block rounded border border-border/50 bg-bg-secondary/30 px-6 py-3 text-xs">
              <span class="text-accent">root@l4tentnoise</span>:<span class="text-text-secondary">~</span>#
              <span class="cursor-blink"> </span>
            </div>

            <div class="mt-6 flex items-center justify-center gap-4 text-[10px] text-text-muted/30">
              <span>SESSION: ACTIVE</span>
              <span>|</span>
              <span>ENCRYPTION: AES-256</span>
              <span>|</span>
              <span>EXIT NODE: TOR</span>
            </div>

            <a
              href="/Web-AIR/"
              class="mt-6 inline-block text-xs text-text-muted/40 transition-colors hover:text-accent-red"
            >
              [disconnect]
            </a>

            <p class="mt-2 text-[9px] text-text-muted/20">
              This session was not supposed to be accessible.
            </p>
          </div>
        </footer>
      </div>
    </L4tentNoiseShell>
</L4tentLayout>
