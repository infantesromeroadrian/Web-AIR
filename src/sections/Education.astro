---
import SectionTitle from "../components/astro/SectionTitle.astro";
import ScrollReveal from "../components/react/ScrollReveal";
import { education, certifications } from "../data/education";
---

<section class="px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle title="Education" />

    <div class="grid gap-6 sm:grid-cols-2">
      {education.map((edu, i) => (
        <ScrollReveal client:visible delay={i * 0.08}>
          <div class="h-full rounded-xl border border-border bg-bg-secondary/50 p-5 transition-all duration-200 hover:border-border-hover">
            <h3 class="font-semibold text-text-primary">{edu.institution}</h3>
            <p class="mt-1 text-sm text-text-secondary">{edu.degree}</p>
            {edu.specialization && (
              <p class="mt-1 text-xs text-accent">Specialization: {edu.specialization}</p>
            )}
          </div>
        </ScrollReveal>
      ))}
    </div>

    <!-- Certifications -->
    <ScrollReveal client:visible delay={0.2}>
      <div class="mt-10">
        <h3 class="mb-4 text-lg font-semibold text-text-primary">Certifications</h3>
        <div class="flex flex-wrap gap-2">
          {certifications.map((cert) => (
            <span class="rounded-full border border-border bg-bg-secondary/50 px-4 py-1.5 text-sm text-text-secondary transition-colors hover:border-border-hover">
              {cert}
            </span>
          ))}
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
