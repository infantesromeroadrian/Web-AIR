---
import SectionTitle from "../components/astro/SectionTitle.astro";
import ScrollReveal from "../components/react/ScrollReveal";
import VideoPreview from "../components/react/VideoPreview";
import { projects } from "../data/projects";
---

<section id="projects" class="px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle
      title="Featured Projects"
      subtitle="Real systems, real code, real impact"
    />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.filter((p) => p.featured).map((project, i) => (
        <ScrollReveal client:visible delay={i * 0.08}>
          <div class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-border bg-bg-secondary/50 transition-all duration-300 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
            <!-- Video / Placeholder -->
            {project.videoSrc ? (
              <VideoPreview
                client:visible
                src={project.videoSrc}
                title={project.title}
              />
            ) : (
              <div class="flex aspect-video items-center justify-center bg-bg-tertiary">
                <span class="font-mono text-4xl text-accent/20">&gt;_</span>
              </div>
            )}

            <!-- Content -->
            <div class="flex flex-1 flex-col p-5">
              <h3 class="text-lg font-bold text-text-primary">{project.title}</h3>
              <p class="mt-1 text-sm text-accent">{project.headline}</p>
              <p class="mt-3 flex-1 text-sm text-text-secondary line-clamp-2">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="mt-4 flex flex-wrap gap-1.5">
                {project.tags.slice(0, 4).map((tag) => (
                  <span class="rounded bg-bg-tertiary px-2 py-0.5 text-xs text-text-muted">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="mt-4 flex items-center gap-3 border-t border-border pt-4">
                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group/link flex items-center gap-1.5 text-sm text-text-muted transition-colors hover:text-accent"
                >
                  GitHub
                  <span class="inline-block transition-transform group-hover/link:translate-x-0.5">&rarr;</span>
                </a>
              </div>
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
