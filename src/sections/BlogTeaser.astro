---
import SectionTitle from "../components/astro/SectionTitle.astro";
import ScrollReveal from "../components/react/ScrollReveal";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const hasPosts = posts.some((p) => !p.data.draft);
---

<section class="bg-bg-secondary/20 px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle
      title="Writing"
      subtitle="Technical deep dives on AI Security, Red Teaming, and ML Engineering"
    />

    <ScrollReveal client:visible>
      {hasPosts ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.filter((p) => !p.data.draft).map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group rounded-xl border border-border bg-bg-secondary/50 p-6 transition-all hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5"
            >
              <time class="text-xs text-text-muted" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-US", { month: "short", year: "numeric" })}
              </time>
              <h3 class="mt-2 font-bold text-text-primary transition-colors group-hover:text-accent line-clamp-2">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-text-secondary line-clamp-2">{post.data.description}</p>
            </a>
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-border bg-bg-secondary/50 p-8 text-center">
          <p class="font-mono text-sm text-text-muted">
            <span class="text-accent">$</span> echo "Posts in the pipeline"
          </p>
          <p class="mt-3 text-sm text-text-secondary">
            Technical writeups on AI Red Teaming, multi-agent architectures, and production ML coming soon.
          </p>
          <div class="mt-4 flex flex-wrap items-center justify-center gap-2">
            {["AI Red Teaming", "LangGraph", "Edge AI", "MLOps"].map((tag) => (
              <span class="rounded bg-bg-tertiary px-3 py-1 text-xs text-text-muted">{tag}</span>
            ))}
          </div>
        </div>
      )}
    </ScrollReveal>
  </div>
</section>
