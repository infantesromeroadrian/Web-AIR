---
import SectionTitle from "../components/astro/SectionTitle.astro";
import ScrollReveal from "../components/react/ScrollReveal";
import AttackExplorer from "../components/react/AttackExplorer";
---

<section id="attacks" class="px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle
      title="Breaking the Model"
      subtitle="Two angles on adversarial attacks against Foundation Models"
    />

    <ScrollReveal client:visible>
      <AttackExplorer client:visible />
    </ScrollReveal>
  </div>
</section>
