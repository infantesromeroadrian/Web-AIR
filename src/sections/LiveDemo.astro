---
import SectionTitle from "../components/astro/SectionTitle.astro";
import ScrollReveal from "../components/react/ScrollReveal";
import PhishingAnalyzer from "../components/react/PhishingAnalyzer";
---

<section id="demo" class="bg-bg-secondary/20 px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle
      title="Live Demo"
      subtitle="Try it yourself — AI-powered email threat analysis running in your browser"
    />

    <ScrollReveal client:visible>
      <div class="mx-auto max-w-3xl">
        <PhishingAnalyzer client:visible />
      </div>
    </ScrollReveal>
  </div>
</section>
