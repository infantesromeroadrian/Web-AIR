---
import SectionTitle from "../components/astro/SectionTitle.astro";
import ScrollReveal from "../components/react/ScrollReveal";
import NeuralBreach from "../components/react/NeuralBreach";
---

<section id="breach" class="bg-bg-secondary/20 px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle
      title="Breaking the Model"
      subtitle="What adversarial attacks on Foundation Models actually look like"
    />

    <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr] lg:items-center">
      <ScrollReveal client:visible>
        <NeuralBreach client:visible />
      </ScrollReveal>

      <ScrollReveal client:visible delay={0.15}>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-accent/30 bg-accent/5 font-mono text-xs text-accent">
              01
            </div>
            <div>
              <h3 class="font-bold text-text-primary">Inference path</h3>
              <p class="mt-1 text-sm text-text-secondary">
                A request enters the network. Signals propagate through hidden layers. The model outputs a confident prediction &mdash; this is the happy path.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-accent-amber/30 bg-accent-amber/5 font-mono text-xs" style="color: var(--color-accent-amber);">
              02
            </div>
            <div>
              <h3 class="font-bold text-text-primary">Adversarial injection</h3>
              <p class="mt-1 text-sm text-text-secondary">
                I craft a perturbation so subtle the model can't tell it apart from valid input. Prompt injection for LLMs, FGSM / PGD for vision, imperceptible to humans, surgical to the model.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-accent-red/30 bg-accent-red/5 font-mono text-xs" style="color: var(--color-accent-red);">
              03
            </div>
            <div>
              <h3 class="font-bold text-text-primary">Breach propagation</h3>
              <p class="mt-1 text-sm text-text-secondary">
                The adversarial signal cascades layer by layer, corrupting activations. The final output flips from <span class="font-mono text-[var(--color-accent-green)]">SAFE</span> to <span class="font-mono text-[var(--color-accent-red)]">COMPROMISED</span> &mdash; exactly what I document before it ships to production at BBVA.
              </p>
            </div>
          </div>

          <div class="rounded-lg border border-border bg-bg-secondary/50 p-4 font-mono text-xs text-text-muted">
            <span class="text-accent">206+</span> attack vectors documented.
            <span class="text-accent">7</span> critical findings remediated pre-deploy.
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
