---
import SectionTitle from "../components/astro/SectionTitle.astro";
import ScrollReveal from "../components/react/ScrollReveal";
import SkillGraph3D from "../components/react/SkillGraph3D";
import { getLangFromUrl, t } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
---

<section class="bg-bg-secondary/20 px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle
      title={t("topology.title", lang)}
      subtitle={t("topology.subtitle", lang)}
    />

    <ScrollReveal client:visible>
      <SkillGraph3D client:visible />
    </ScrollReveal>
  </div>
</section>
