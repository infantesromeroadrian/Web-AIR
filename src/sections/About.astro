---
import SectionTitle from "../components/astro/SectionTitle.astro";
import AnimatedCounter from "../components/react/AnimatedCounter";
import ScrollReveal from "../components/react/ScrollReveal";
import profileImage from "../../assets/Gemini_Generated_Image_ne74yhne74yhne74.png";
import { Image } from "astro:assets";
import { getLangFromUrl, t } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const metrics = [
  { value: "6+", label: t("about.metric.years", lang) },
  { value: "206+", label: t("about.metric.attacks", lang) },
  { value: "800", label: t("about.metric.htb", lang) },
  { value: "-20%", label: t("about.metric.latency", lang) },
  { value: "-35%", label: t("about.metric.costs", lang) },
  { value: "45K", label: t("about.metric.throughput", lang) },
];
---

<section id="about" class="bg-bg-secondary/20 px-6 py-24">
  <div class="mx-auto max-w-[var(--max-w-content)]">
    <SectionTitle title={t("about.title", lang)} />

    <div class="grid gap-12 lg:grid-cols-[300px_1fr]">
      <!-- Photo -->
      <ScrollReveal client:visible direction="left">
        <div class="flex justify-center lg:justify-start">
          <div class="relative overflow-hidden rounded-2xl border border-border">
            <Image
              src={profileImage}
              alt="Adrian Infantes in a data center"
              width={300}
              height={400}
              class="object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-bg-primary/60 to-transparent"></div>
          </div>
        </div>
      </ScrollReveal>

      <!-- Content -->
      <div>
        <ScrollReveal client:visible delay={0.1}>
          <p class="text-lg leading-relaxed text-text-secondary">
            {t("about.p1.prefix", lang)}
            <span class="font-medium text-text-primary">{t("about.p1.strong", lang)}</span>{t("about.p1.suffix", lang)}
          </p>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.2}>
          <p class="mt-4 text-text-secondary">
            {t("about.p2", lang)}
          </p>
        </ScrollReveal>

        <!-- Animated metrics grid -->
        <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3">
          {metrics.map((m) => (
            <AnimatedCounter
              client:visible
              value={m.value}
              label={m.label}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
