---
import { SOCIAL_LINKS, SITE } from "../../lib/constants";
import { getLangFromUrl, t } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-border bg-bg-secondary/80 px-6 py-12 backdrop-blur-sm">
  <div class="mx-auto flex max-w-[var(--max-w-content)] flex-col items-center gap-6">
    <div class="flex items-center gap-6">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted transition-colors duration-200 hover:text-accent"
          aria-label={link.name}
        >
          {link.name}
        </a>
      ))}
    </div>

    <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm text-text-muted">
      <span>&copy; {year} {SITE.author}.</span>
      <span>{t("footer.rights", lang)}</span>
      <span class="hidden sm:inline">{t("footer.built", lang)}</span>
      <span class="text-text-muted/50">|</span>
      <button
        id="terminal-hint"
        class="font-mono text-xs text-text-muted/40 transition-colors duration-200 hover:text-accent"
        aria-label={t("footer.terminal", lang)}
      >
        Ctrl+K
      </button>
    </div>
  </div>
</footer>

<script>
  document.getElementById("terminal-hint")?.addEventListener("click", () => {
    window.dispatchEvent(new KeyboardEvent("keydown", { key: "k", ctrlKey: true }));
  });
</script>
