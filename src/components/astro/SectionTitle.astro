---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="mb-12" id={id}>
  <h2 class="text-3xl font-bold tracking-tight text-text-primary">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-2 text-text-secondary">{subtitle}</p>
  )}
  <div class="mt-4 h-px w-16 bg-accent"></div>
</div>
