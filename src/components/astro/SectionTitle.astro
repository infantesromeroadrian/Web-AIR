---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
  center?: boolean;
}

const { title, subtitle, id, center = false } = Astro.props;
---

<div class:list={["mb-12", { "text-center": center }]} id={id}>
  <h2 class="text-3xl font-bold tracking-tight text-text-primary">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-2 text-text-secondary">{subtitle}</p>
  )}
  <div class:list={["mt-4 h-px w-16 bg-accent", { "mx-auto": center }]}></div>
</div>
